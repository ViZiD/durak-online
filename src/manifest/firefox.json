{
  "manifest_version": 2,
  "browser_action": {
    "browser_style": true,
    "default_title": "durak online helper",
    "default_popup": "assets/html/popup.html"
  },
  "background": {
    "scripts": [
      "worker/worker.js"
    ],
    "persistent": true
  },
  "permissions": [
    "*://durakonline.ru/*",
    "storage"
  ],
  "web_accessible_resources": [
    "content/scripts/wshook.js",
    "assets/styles/helper.css"
  ]
}
