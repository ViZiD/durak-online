{
  "version": "1.0.0",
  "name": "durak online helper",
  "description": "durak online tools and helpers",
  "icons": {
    "128": "assets/icons/128.png"
  },
  "content_scripts": [
    {
      "run_at": "document_idle",
      "js": [
        "content/main.js"
      ],
      "matches": [
        "https://durakonline.ru/*"
      ]
    }
  ],
  "manifest_version": 3,
  "action": {
    "default_title": "durak online helper",
    "default_popup": "assets/html/popup.html"
  },
  "background": {
    "service_worker": "worker/worker.js",
    "type": "module"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://durakonline.ru/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/scripts/wshook.js"
      ],
      "matches": [
        "*://durakonline.ru/*"
      ]
    }
  ]
}